  "info": {
    "_postman_id": "b516f7b3-d139-4800-81bd-bf5078a7e05b",
    "name": "Vite Plugin API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Vite Plugin API extends Rolldown's plugin interface with Vite-specific hooks for controlling the build pipeline, configuring the development server, transforming HTML entry points, and managing hot module replacement (HMR). Plugins are plain JavaScript objects returned from a factory function and can hook into both serve (dev) and build phases.\n\nContact Support:\n Name: Vite Team",
      "type": "text/plain"
    }
  }
